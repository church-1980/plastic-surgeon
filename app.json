{
  "expo": {
    "name": "The Plastic Surgeon",
    "slug": "plastic-surgeon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "plasticsurgeon",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jestersworkshop.plasticsurgeon"
    },
    "android": {
      "package": "com.jestersworkshop.plasticsurgeon",
      "adaptiveIcon": {
        "backgroundColor": "#FF6B2B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F1117",
          "dark": {
            "backgroundColor": "#0F1117"
          }
        }
      ],
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "The Plastic Surgeon uses your camera to photograph printer components during inspections. Photos are stored only on your device."
        }
      ],
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "The Plastic Surgeon uses your photos to attach inspection images to maintenance records.",
          "cameraPermission": "The Plastic Surgeon uses your camera to photograph printer components during visual inspections."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "76b0bf52-368b-4a61-90e4-66359f869c02"
      }
    },
    "owner": "paulrollin"
  }
}
